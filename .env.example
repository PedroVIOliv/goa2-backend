# Environment: "development" or "production"
GOA2_ENV=development

# Server port
GOA2_PORT=8000

# Allowed frontend origins for CORS (comma-separated)
# Example: GOA2_CORS_ORIGINS=https://goa2.vercel.app,https://my-other-domain.com
GOA2_CORS_ORIGINS=
# Regex pattern for allowed CORS origins (e.g., https://.*-goa2-frontend\\.pedrovelosoio\\.workers\\.dev)
GOA2_CORS_ORIGIN_REGEX=

# Game data directories
GOA2_SAVE_DIR=data/games
GOA2_LOG_DIR=logs/games

# Minimal replay logs (setup + decisions; used to reconstruct games for debugging)
GOA2_REPLAY_DIR=data/replays
# How long replay logs are retained, in days
GOA2_REPLAY_TTL_DAYS=30
