# Environment: "development" or "production"
GOA2_ENV=development

# Server port
GOA2_PORT=8000

# Allowed frontend origins for CORS (comma-separated)
# Example: GOA2_CORS_ORIGINS=https://goa2.vercel.app,https://my-other-domain.com
GOA2_CORS_ORIGINS=

# Game data directories
GOA2_SAVE_DIR=data/games
GOA2_LOG_DIR=logs/games
